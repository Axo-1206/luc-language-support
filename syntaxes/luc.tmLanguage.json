{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "luc",
	"scopeName": "source.luc",
	"patterns": [
		{
			"include": "#doc_comments"
		},
		{
			"include": "#block_comments"
		},
		{
			"include": "#line_comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#chars"
		},
		{
			"include": "#numerics"
		},
		{
			"include": "#keywords_declaration"
		},
		{
			"include": "#keywords_module"
		},
		{
			"include": "#keywords_control"
		},
		{
			"include": "#keywords_logical"
		},
		{
			"include": "#keywords_constants"
		},
		{
			"include": "#storage_modifiers"
		},
		{
			"include": "#type_decl_keywords"
		},
		{
			"include": "#primitive_types"
		},
		{
			"include": "#qualifiers"
		},
		{
			"include": "#intrinsics"
		},
		{
			"include": "#attributes"
		},
		{
			"include": "#operators_pipeline"
		},
		{
			"include": "#operators_nullable"
		},
		{
			"include": "#operators_compound_assign_bitwise"
		},
		{
			"include": "#operators_compound_assign"
		},
		{
			"include": "#operators_comparison"
		},
		{
			"include": "#operators_bitwise"
		},
		{
			"include": "#operators_arithmetic"
		},
		{
			"include": "#operators_misc"
		},
		{
			"include": "#punctuation"
		}
	],
	"repository": {
		"doc_comments": {
			"comment": "Doc block comment: /-- ... --/",
			"name": "comment.block.documentation.luc",
			"begin": "/--",
			"end": "--/"
		},
		"block_comments": {
			"comment": "Plain block comment: /- ... -/",
			"name": "comment.block.luc",
			"begin": "/-",
			"end": "-/"
		},
		"line_comments": {
			"comment": "Single-line comment: -- ...",
			"name": "comment.line.double-dash.luc",
			"match": "--.*$"
		},
		"strings": {
			"patterns": [
				{
					"comment": "Raw string with hash delimiters: r##\"...\"## (match before plain r\")",
					"name": "string.quoted.other.raw.luc",
					"begin": "r#+\"",
					"end": "\"#+",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.luc"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.luc"
						}
					}
				},
				{
					"comment": "Raw string literal: r\"...\" (no escape processing)",
					"name": "string.quoted.other.raw.luc",
					"begin": "r\"",
					"end": "\"",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.luc"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.luc"
						}
					}
				},
				{
					"comment": "Regular string literal: \"...\" with escape sequences",
					"name": "string.quoted.double.luc",
					"begin": "\"",
					"end": "\"",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.luc"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.luc"
						}
					},
					"patterns": [
						{
							"comment": "Unicode escape: \\UXXXXXXXX (8 hex digits)",
							"name": "constant.character.escape.unicode.long.luc",
							"match": "\\\\U[0-9a-fA-F]{8}"
						},
						{
							"comment": "Unicode escape: \\uXXXX (4 hex digits)",
							"name": "constant.character.escape.unicode.luc",
							"match": "\\\\u[0-9a-fA-F]{4}"
						},
						{
							"comment": "Hex byte escape: \\xHH",
							"name": "constant.character.escape.hex.luc",
							"match": "\\\\x[0-9a-fA-F]{2}"
						},
						{
							"comment": "Standard single-char escapes: \\n \\t \\r \\\\ \\\" \\' \\0",
							"name": "constant.character.escape.luc",
							"match": "\\\\[ntr\\\\\"'0]"
						},
						{
							"comment": "Unrecognised escape — surfaces as an error",
							"name": "invalid.illegal.escape.luc",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"chars": {
			"comment": "Char literal: 'a'  '\\n'",
			"name": "string.quoted.single.luc",
			"begin": "'",
			"end": "'",
			"patterns": [
				{
					"name": "constant.character.escape.unicode.long.luc",
					"match": "\\\\U[0-9a-fA-F]{8}"
				},
				{
					"name": "constant.character.escape.unicode.luc",
					"match": "\\\\u[0-9a-fA-F]{4}"
				},
				{
					"name": "constant.character.escape.hex.luc",
					"match": "\\\\x[0-9a-fA-F]{2}"
				},
				{
					"name": "constant.character.escape.luc",
					"match": "\\\\[ntr\\\\\"'0]"
				}
			]
		},
		"numerics": {
			"patterns": [
				{
					"comment": "Hex literal: 0xFF  0xDEAD_BEEF",
					"name": "constant.numeric.hex.luc",
					"match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
				},
				{
					"comment": "Binary literal: 0b1010  0b1111_0000",
					"name": "constant.numeric.binary.luc",
					"match": "\\b0[bB][01][01_]*\\b"
				},
				{
					"comment": "Float with optional exponent: 3.14  1.5e-3",
					"name": "constant.numeric.float.luc",
					"match": "\\b\\d[\\d_]*\\.[\\d_]*([eE][+\\-]?\\d[\\d_]*)?\\b"
				},
				{
					"comment": "Float exponent without decimal point: 1e10",
					"name": "constant.numeric.float.luc",
					"match": "\\b\\d[\\d_]*[eE][+\\-]?\\d[\\d_]*\\b"
				},
				{
					"comment": "Integer literal: 42  1_000_000",
					"name": "constant.numeric.integer.luc",
					"match": "\\b\\d[\\d_]*\\b"
				}
			]
		},
		"keywords_declaration": {
			"comment": "Variable / function declaration keywords: let const",
			"name": "keyword.declaration.luc",
			"match": "\\b(let|const)\\b"
		},
		"keywords_module": {
			"comment": "Module-system keywords: package use as",
			"name": "keyword.other.module.luc",
			"match": "\\b(package|use|as)\\b"
		},
		"keywords_control": {
			"comment": "Control-flow keywords (await is concurrency, not a qualifier)",
			"name": "keyword.control.luc",
			"match": "\\b(if|else|match|switch|case|default|is|while|for|in|do|return|break|continue|await)\\b"
		},
		"keywords_logical": {
			"comment": "Word-form logical operators: and or not",
			"name": "keyword.operator.logical.luc",
			"match": "\\b(and|or|not)\\b"
		},
		"keywords_constants": {
			"comment": "Language-level constants: true false nil",
			"name": "constant.language.luc",
			"match": "\\b(true|false|nil)\\b"
		},
		"storage_modifiers": {
			"comment": "Visibility / scope modifiers: pub export",
			"name": "storage.modifier.luc",
			"match": "\\b(pub|export)\\b"
		},
		"type_decl_keywords": {
			"comment": "Type-declaration keywords: struct enum trait type impl from",
			"name": "keyword.declaration.type.luc",
			"match": "\\b(struct|enum|trait|type|impl|from)\\b"
		},
		"primitive_types": {
			"comment": "Built-in primitive type names",
			"name": "support.type.primitive.luc",
			"match": "\\b(bool|byte|short|int|long|ubyte|ushort|uint|ulong|int8|int16|int32|int64|uint8|uint16|uint32|uint64|float|double|decimal|string|char|any)\\b"
		},
		"qualifiers": {
			"comment": "Type qualifiers: ~async ~nullable ~parallel (tilde + identifier)",
			"match": "(~)(async|nullable|parallel)\\b",
			"captures": {
				"1": {
					"name": "keyword.operator.qualifier.sigil.luc"
				},
				"2": {
					"name": "keyword.other.qualifier.luc"
				}
			}
		},
		"intrinsics": {
			"comment": "Compiler intrinsics: #name(...)",
			"match": "(#)([a-zA-Z_][a-zA-Z0-9_]*)",
			"captures": {
				"1": {
					"name": "keyword.operator.intrinsic.sigil.luc"
				},
				"2": {
					"name": "support.function.intrinsic.luc"
				}
			}
		},
		"attributes": {
			"comment": "Declaration attributes: @name or @name(args)",
			"match": "(@)([a-zA-Z_][a-zA-Z0-9_]*)",
			"captures": {
				"1": {
					"name": "keyword.operator.attribute.sigil.luc"
				},
				"2": {
					"name": "entity.name.attribute.luc"
				}
			}
		},
		"operators_pipeline": {
			"patterns": [
				{
					"comment": "Composition operator: +>  (compile-time, must match before +)",
					"name": "keyword.operator.compose.luc",
					"match": "\\+>"
				},
				{
					"comment": "Pipeline operator: |>  (runtime, must match before |)",
					"name": "keyword.operator.pipeline.luc",
					"match": "\\|>"
				},
				{
					"comment": "Return boundary / arrow: ->  (must match before - and >)",
					"name": "keyword.operator.arrow.luc",
					"match": "->"
				},
				{
					"comment": "Fat arrow: =>  (match arm body separator, must match before =)",
					"name": "keyword.operator.fat-arrow.luc",
					"match": "=>"
				}
			]
		},
		"operators_nullable": {
			"patterns": [
				{
					"comment": "Nil-coalescing / if-expression separator: ??  (must match before ?)",
					"name": "keyword.operator.nullcoalesce.luc",
					"match": "\\?\\?"
				},
				{
					"comment": "Nullable chain accessor: ?.  (must match before ? and .)",
					"name": "keyword.operator.nullchain.luc",
					"match": "\\?\\."
				},
				{
					"comment": "Nullable type suffix: ?",
					"name": "keyword.operator.nullable.luc",
					"match": "\\?"
				}
			]
		},
		"operators_compound_assign_bitwise": {
			"comment": "Bitwise compound assignment (must match before plain bitwise ops): &&= ||= ~^= <<= >>=",
			"name": "keyword.operator.assignment.compound.bitwise.luc",
			"match": "(&&=|\\|\\|=|~\\^=|<<=|>>=)"
		},
		"operators_compound_assign": {
			"comment": "Arithmetic compound assignment: += -= *= /= ^= %=",
			"name": "keyword.operator.assignment.compound.luc",
			"match": "(\\+=|-=|\\*=|/=|\\^=|%=)"
		},
		"operators_comparison": {
			"patterns": [
				{
					"comment": "Reference equality: ===  (must match before ==)",
					"name": "keyword.operator.comparison.reference.luc",
					"match": "==="
				},
				{
					"comment": "Value equality / inequality: == !=",
					"name": "keyword.operator.comparison.equality.luc",
					"match": "(==|!=)"
				},
				{
					"comment": "Ordered comparison: <= >=  (must match before < and >)",
					"name": "keyword.operator.comparison.ordered.luc",
					"match": "(<=|>=)"
				},
				{
					"comment": "Less-than / greater-than: < >",
					"name": "keyword.operator.comparison.luc",
					"match": "(<|>)"
				}
			]
		},
		"operators_bitwise": {
			"patterns": [
				{
					"comment": "Bitwise NOT (double tilde): ~~  (must match before ~ qualifier prefix)",
					"name": "keyword.operator.bitwise.not.luc",
					"match": "~~"
				},
				{
					"comment": "Bitwise AND: &&  (must match before bare & reference operator)",
					"name": "keyword.operator.bitwise.and.luc",
					"match": "&&"
				},
				{
					"comment": "Bitwise OR: ||  (must match before | pipeline separator)",
					"name": "keyword.operator.bitwise.or.luc",
					"match": "\\|\\|"
				},
				{
					"comment": "Bitwise XOR: ~^  (must match before ~ qualifier prefix)",
					"name": "keyword.operator.bitwise.xor.luc",
					"match": "~\\^"
				},
				{
					"comment": "Left shift: <<  (must match before <)",
					"name": "keyword.operator.bitwise.shift.left.luc",
					"match": "<<"
				},
				{
					"comment": "Right shift: >>  (must match before >)",
					"name": "keyword.operator.bitwise.shift.right.luc",
					"match": ">>"
				}
			]
		},
		"operators_arithmetic": {
			"comment": "Arithmetic: + - * / % ^",
			"name": "keyword.operator.arithmetic.luc",
			"match": "(\\+|-|\\*|/|%|\\^)"
		},
		"operators_misc": {
			"patterns": [
				{
					"comment": "Argument-pack annotation: !  (pipeline step marker, must match before !=)",
					"name": "keyword.operator.pack.luc",
					"match": "!"
				},
				{
					"comment": "Variadic parameter marker: ...  (must match before ..)",
					"name": "keyword.operator.variadic.luc",
					"match": "\\.\\.\\."
				},
				{
					"comment": "Exclusive range operator: ..<  (must match before ..)",
					"name": "keyword.operator.range.exclusive.luc",
					"match": "\\.\\.<"
				},
				{
					"comment": "Inclusive range operator: ..",
					"name": "keyword.operator.range.luc",
					"match": "\\.\\."
				},
				{
					"comment": "Safe reference type / take-reference: &",
					"name": "keyword.operator.reference.luc",
					"match": "&"
				},
				{
					"comment": "Bitwise-OR / pipe separator: |  (lone pipe, after |> and || matched)",
					"name": "keyword.operator.pipe.luc",
					"match": "\\|"
				},
				{
					"comment": "Plain assignment: =  (after ==, ===, =>, +=, etc. already matched)",
					"name": "keyword.operator.assignment.luc",
					"match": "="
				},
				{
					"comment": "Wildcard pattern in match: _",
					"name": "variable.language.wildcard.luc",
					"match": "\\b_\\b"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"comment": "Behavior-member / impl-namespace access / generic constraint: :",
					"name": "punctuation.accessor.impl.luc",
					"match": ":"
				},
				{
					"comment": "Data-member access: .",
					"name": "punctuation.accessor.dot.luc",
					"match": "\\."
				},
				{
					"comment": "Comma separator",
					"name": "punctuation.separator.comma.luc",
					"match": ","
				},
				{
					"comment": "Semicolon separator (optional in Luc)",
					"name": "punctuation.separator.semicolon.luc",
					"match": ";"
				},
				{
					"comment": "Block delimiters: { }",
					"name": "punctuation.definition.block.luc",
					"match": "[{}]"
				},
				{
					"comment": "Group / parameter delimiters: ( )",
					"name": "punctuation.definition.group.luc",
					"match": "[()]"
				},
				{
					"comment": "Array / generic / index delimiters: [ ]",
					"name": "punctuation.definition.array.luc",
					"match": "[\\[\\]]"
				}
			]
		}
	}
}